{
  "name": "@momentocake/whatsapp-worker",
  "version": "0.1.0",
  "private": true,
  "description": "WhatsApp Baileys worker — bridges WhatsApp Web protocol to Firestore for Momento Cake admin.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run --no-file-parallelism",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --no-file-parallelism",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^6.7.21",
    "firebase-admin": "^12.7.0",
    "node-cache": "^5.1.2",
    "pino": "^9.5.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/qrcode": "^1.5.5",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  }
}
