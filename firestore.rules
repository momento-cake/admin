rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions for authentication and authorization
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.type == 'admin' &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive == true;
    }
    
    function isViewer() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.type in ['admin', 'producao', 'atendente'] &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive == true;
    }

    function isAdminOrAtendente() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.type in ['admin', 'atendente'] &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive == true;
    }
    
    function isUserActive() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive == true;
    }
    
    function isOwnerOrAdmin(userId) {
      return isAuthenticated() && (
        request.auth.uid == userId || isAdmin()
      );
    }
    
    function hasBusinessAccess(businessId) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive == true;
    }
    
    function isBusinessAuthorized(businessId) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/businesses/$(businessId)) &&
             request.auth.uid in get(/databases/$(database)/documents/businesses/$(businessId)).data.authorizedUsers;
    }
    
    // System settings collection - allows unauthenticated read for admin check
    match /system/settings {
      // Allow reading system settings to check if admins exist
      allow read: if true;
      // Only admins can write system settings
      allow write: if isAdmin();
    }

    // System admin setup check - allows checking if initial setup is needed
    match /system/adminSetup {
      // Anyone can read to check if setup is complete
      allow read: if true;
      // Only authenticated users can create (for initial setup)
      // Only admins can update/delete after initial creation
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Users collection - Admin and user management
    match /users/{userId} {
      // Users can read their own document, admins can read all
      allow read: if request.auth.uid == userId || isAdmin();

      // Users can update their own profile, admins can update any profile
      allow update: if isOwnerOrAdmin(userId) &&
                    // Prevent role escalation by non-admins
                    (isAdmin() ||
                     (!('role' in request.resource.data.diff(resource.data).affectedKeys()) &&
                      !('isActive' in request.resource.data.diff(resource.data).affectedKeys())));

      // Only admins can create new users or delete users
      // Also allow creating the first admin user when no admins exist (checked via system/adminSetup)
      allow create: if isAdmin() ||
                      (request.auth != null &&
                       request.auth.uid == userId &&
                       request.resource.data.role.type == 'admin' &&
                       !exists(/databases/$(database)/documents/system/adminSetup));

      allow delete: if isAdmin();
    }
    
    // Invitations collection - stores user invitation data
    match /invitations/{invitationId} {
      // Only admins can manage invitations
      allow read, write: if isAdmin();
    }
    
    // Top-level ingredients collection - for system-wide ingredients
    match /ingredients/{ingredientId} {
      // Admins can manage all ingredients, viewers can read
      allow read: if isViewer();
      allow write: if isAdmin();
    }
    
    // Top-level suppliers collection - for system-wide suppliers
    match /suppliers/{supplierId} {
      // Admins can manage all suppliers, viewers can read
      allow read: if isViewer();
      allow write: if isAdmin();
    }
    
    // Stock history collection - for ingredient stock tracking
    match /stockHistory/{stockHistoryId} {
      // Admins can manage all stock history, viewers can read
      allow read: if isViewer();
      allow write: if isAdmin();
    }
    
    // Stock history collection (with underscore) - for ingredient stock tracking
    match /stock_history/{stockHistoryId} {
      // Admins can manage all stock history, viewers can read
      allow read: if isViewer();
      allow write: if isAdmin();
    }
    
    // Price history collection - for ingredient price tracking
    match /priceHistory/{priceHistoryId} {
      // Admins can manage all price history, viewers can read
      allow read: if isViewer();
      allow write: if isAdmin();
    }
    
    // Top-level recipes collection - for system-wide recipes
    match /recipes/{recipeId} {
      // Admins can manage all recipes, viewers can read
      allow read: if isViewer();
      allow write: if isAdmin();
    }

    // Top-level clients collection - for clients management
    //
    // NOTE ON PERMISSION GRANULARITY: Firestore rules only enforce base-level
    // role checks (admin vs atendente). They cannot enforce the custom
    // per-user permission granularity defined in the app layer (e.g., revoking
    // 'create' from a specific atendente while allowing 'view' and 'update').
    // Granular permission enforcement happens in the API routes via
    // canPerformActionFromRequest() (see src/lib/api-auth.ts) and in the UI
    // via canPerformAction() (see src/lib/permissions.ts).
    match /clients/{clientId} {
      // Admin and atendente can read clients
      allow read: if isAdminOrAtendente();
      // Admin and atendente can create and update clients
      allow create, update: if isAdminOrAtendente();
      // Only admin can delete clients
      allow delete: if isAdmin();
    }

    // Packaging collection - for packaging item management
    match /packaging/{packagingId} {
      // Admins can manage all packaging items, viewers can read
      allow read: if isViewer();
      allow write: if isAdmin();
    }

    // Packaging stock history collection - for tracking packaging stock movements
    match /packaging_stock_history/{historyId} {
      // Admins can manage all stock history, viewers can read
      allow read: if isViewer();
      allow write: if isAdmin();
    }

    // Packaging price history collection - for tracking packaging price changes
    match /packaging_price_history/{historyId} {
      // Admins can manage all price history, viewers can read
      allow read: if isViewer();
      allow write: if isAdmin();
    }

    // Recipe settings collection - for system-wide recipe configuration
    match /recipe_settings/{settingsId} {
      // Admins can manage recipe settings, viewers can read
      allow read: if isViewer();
      allow write: if isAdmin();
    }

    // Products collection - Product catalog management
    match /products/{productId} {
      // Admins can manage all products, viewers can read
      allow read: if isViewer();
      allow create, update, delete: if isAdmin();
    }

    // Product Categories collection - Category management
    match /productCategories/{categoryId} {
      // All authenticated users can read categories, only admins can write
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Product Subcategories collection - Subcategory management
    match /productSubcategories/{subcategoryId} {
      // All authenticated users can read subcategories, only admins can write
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Gallery Images collection - Image reference management
    match /gallery_images/{imageId} {
      // All authenticated users can read images (viewers can see gallery)
      allow read: if isViewer();
      // Authenticated users can create images
      allow create: if isUserActive();
      // Users can update/delete their own images, admins can update/delete any
      allow update, delete: if isAdmin() ||
                             (isUserActive() && resource.data.uploadedBy == request.auth.uid);
    }

    // Image Tags collection - Tag management for images
    match /image_tags/{tagId} {
      // All authenticated users can read tags
      allow read: if isViewer();
      // Authenticated users can create tags
      allow create: if isUserActive();
      // Users can update/delete their own tags, admins can update/delete any
      allow update, delete: if isAdmin() ||
                             (isUserActive() && resource.data.createdBy == request.auth.uid);
    }

    // Image Folders collection - Folder/gallery management
    match /image_folders/{folderId} {
      // All authenticated users can read folders
      allow read: if isViewer();
      // Authenticated users can create folders
      allow create: if isUserActive();
      // Users can update/delete their own folders, admins can update/delete any
      allow update, delete: if isAdmin() ||
                             (isUserActive() && resource.data.createdBy == request.auth.uid);
    }

    // Time entries collection - Employee time tracking (Controle de Ponto)
    // NOTE: Permissive rules - granular permission enforcement happens in API routes
    match /time_entries/{entryId} {
      allow read, write: if true;
    }

    // Time entry audit logs - Audit trail for time entry modifications
    // NOTE: Permissive rules - granular permission enforcement happens in API routes
    match /time_entry_audit_logs/{logId} {
      allow read, write: if true;
    }

    // Work schedules collection - Employee work schedule management
    // NOTE: Permissive rules - granular permission enforcement happens in API routes
    match /work_schedules/{scheduleId} {
      allow read, write: if true;
    }

    // Workplace locations collection - Physical work locations
    // NOTE: Permissive rules - granular permission enforcement happens in API routes
    match /workplace_locations/{locationId} {
      allow read, write: if true;
    }

    // Holidays collection - Public/municipal holiday calendar
    // NOTE: Permissive rules - granular permission enforcement happens in API routes
    match /holidays/{holidayId} {
      allow read, write: if true;
    }

    // SKU Counters collection - Internal counter management for SKU generation
    match /skuCounters/{document=**} {
      // Only admins can access SKU counters (used via transactions for SKU generation)
      allow read, write: if isAdmin();
    }

    // Pedidos collection - Order management
    // NOTE: Public-token customer access (PIX/card checkout) is intentionally
    // bypassed via the Admin SDK in src/app/api/public/pedidos/**; the public
    // token lives in the request body, so these rules CANNOT enforce it and
    // MUST NOT be relied on for token-based access control. Any future
    // client-side query against /pedidos MUST come from an authenticated
    // admin/atendente user — never expose this collection to anon clients.
    match /pedidos/{pedidoId} {
      allow read: if isViewer();
      allow create: if isAdmin() || (isUserActive());
      allow update: if isAdmin() || (isUserActive());
      allow delete: if isAdmin();
    }

    // Store Addresses collection - Store location management
    match /storeAddresses/{addressId} {
      allow read: if isViewer();
      allow write: if isAdmin();
    }

    // Store Settings collection - Store configuration (freight, etc.)
    match /storeSettings/{document} {
      allow read: if isViewer();
      allow write: if isAdmin();
    }

    // Store Hours collection - Store operating hours
    match /storeHours/{dayId} {
      allow read: if true; // Public page needs this
      allow write: if isAdmin();
    }

    // Pedido Counter collection - Auto-increment counter for pedido numbers
    match /pedidoCounters/{document} {
      allow read, write: if isUserActive();
    }

    // Businesses collection - Business entity management
    match /businesses/{businessId} {
      // Admins can read all, authorized users can read their business
      allow read: if isAdmin() || isBusinessAuthorized(businessId);
      
      // Only admins can create/update/delete business documents
      allow create, update, delete: if isAdmin();
      
      // Business sub-collections
      match /clients/{clientId} {
        // Admins can access all, business users can access their business data
        allow read, write: if isAdmin() || hasBusinessAccess(businessId) || isBusinessAuthorized(businessId);
      }
      
      match /ingredients/{ingredientId} {
        // Admins can access all, business users can access their business data
        allow read, write: if isAdmin() || hasBusinessAccess(businessId) || isBusinessAuthorized(businessId);
      }
      
      match /recipes/{recipeId} {
        // Admins can access all, business users can access their business data
        allow read, write: if isAdmin() || hasBusinessAccess(businessId) || isBusinessAuthorized(businessId);
      }
      
      match /vendors/{vendorId} {
        // Admins can access all, business users can access their business data
        allow read, write: if isAdmin() || hasBusinessAccess(businessId) || isBusinessAuthorized(businessId);
      }
      
      match /orders/{orderId} {
        // Admins can access all, business users can access their business data
        allow read, write: if isAdmin() || hasBusinessAccess(businessId) || isBusinessAuthorized(businessId);
      }
      
      match /reports/{reportId} {
        // Admins can access all, business users can access their business data
        allow read, write: if isAdmin() || hasBusinessAccess(businessId) || isBusinessAuthorized(businessId);
      }
    }
    
    // WhatsApp collections - Inbox + chat-to-pedido feature
    //
    // The worker (packages/whatsapp-worker) uses the Firebase Admin SDK, which
    // bypasses these rules entirely. Client-side access from the admin app is
    // gated by 'whatsapp' feature permission via canPerformActionFromRequest()
    // in API routes. These Firestore rules enforce only the coarse role-level
    // access (admin and atendente).

    // whatsapp_sessions: Baileys auth state. Sensitive (signal protocol keys).
    // Worker writes via Admin SDK; clients have NO access.
    match /whatsapp_sessions/{instanceId} {
      allow read, write: if false;
      match /keys/{keyId} {
        allow read, write: if false;
      }
    }

    // whatsapp_status: connection state + QR code for the settings page.
    // Read by admin/atendente; written by worker (Admin SDK).
    match /whatsapp_status/{instanceId} {
      allow read: if isAdminOrAtendente();
      allow write: if false;
    }

    // whatsapp_conversations: one doc per phone number.
    // Read by admin/atendente. Update allowed for linking clients
    // (clienteId, clienteNome) and resetting unreadCount; create/delete only via
    // Admin SDK (worker upserts on incoming messages).
    match /whatsapp_conversations/{conversationId} {
      allow read: if isAdminOrAtendente();
      allow update: if isAdminOrAtendente();
      allow create, delete: if false;
    }

    // whatsapp_messages: flat collection of all messages, both directions.
    // Read by admin/atendente. Worker writes via Admin SDK.
    match /whatsapp_messages/{messageId} {
      allow read: if isAdminOrAtendente();
      allow write: if false;
    }

    // whatsapp_outbox: outgoing message queue.
    // Admin/atendente create messages; worker drains via Admin SDK.
    // No client-side updates (status transitions are worker-driven).
    match /whatsapp_outbox/{outboxId} {
      allow read, create: if isAdminOrAtendente();
      allow update, delete: if false;
    }

    // whatsapp_sync_jobs: CRM cross-reference jobs.
    // Admin creates a job (via API route) and subscribes to its status doc.
    // Worker drains pending jobs via Admin SDK.
    match /whatsapp_sync_jobs/{jobId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    // System collections (admin only)
    match /system/{document=**} {
      allow read, write: if isAdmin();
    }
    
    match /audit/{document=**} {
      allow read, write: if isAdmin();
    }
    
    // Default deny rule
    match /{document=**} {
      allow read, write: if false;
    }
  }
}